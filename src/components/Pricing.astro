---
import { pricingTiers } from '../data/site';
---

<section id="pricing" class="bg-white py-20 sm:py-24">
  <div class="container-x">
    <div class="max-w-2xl">
      <p class="eyebrow mb-3">Pricing</p>
      <h2 class="mb-4">Simple, Honest Pricing</h2>
      <p class="text-lg text-ink/80">
        Flat rates valley-wide, no surprises. Each plan covers up to two cans —
        add $10 for each extra can. Pick a plan and book online, or request a
        quote and we'll confirm your total within one business day.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        pricingTiers.map((tier) => (
          <article
            class={
              'card flex flex-col ' +
              (tier.featured
                ? 'ring-2 ring-brand-blue/60 shadow-[0_12px_30px_-12px_rgba(0,94,226,0.35)] -translate-y-1'
                : '')
            }
          >
            {tier.featured && (
              <p class="mb-3 inline-flex w-fit items-center rounded-full bg-brand-blue/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-blue">
                Most Popular
              </p>
            )}
            <h3 class="mb-1">{tier.name}</h3>
            <p class="mb-5 text-sm text-ink/60">{tier.cadence}</p>
            <p class="mb-6 font-display text-3xl font-extrabold text-brand-navy">
              {tier.price}
            </p>
            <ul class="mb-8 space-y-2 text-sm text-ink/80">
              {tier.perks.map((perk) => (
                <li class="flex items-start gap-2">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="mt-0.5 h-4 w-4 shrink-0 text-brand-green"
                    aria-hidden="true"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  <span>{perk}</span>
                </li>
              ))}
            </ul>
            <a
              href="#contact"
              class={
                'mt-auto ' +
                (tier.featured ? 'btn-primary' : 'btn-secondary')
              }
            >
              {tier.cta}
            </a>
          </article>
        ))
      }
    </div>

    <p class="mt-8 rounded-xl2 bg-brand-sand/30 px-5 py-4 text-center text-sm font-medium text-brand-navy">
      Prices cover up to 2 cans (trash + recycle). Extra cans are $10 each.
    </p>
  </div>
</section>
