---
import { site } from '../data/site';
---

<section
  id="contact"
  class="relative isolate overflow-hidden bg-brand-navy text-white py-20 sm:py-24"
>
  <!-- decorative gradient -->
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-[radial-gradient(60%_50%_at_20%_0%,rgba(0,94,226,0.35),transparent_70%),radial-gradient(50%_50%_at_85%_100%,rgba(47,143,78,0.25),transparent_70%)]"
  ></div>

  <div class="container-x grid gap-10 lg:grid-cols-2 lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-mint mb-3">
        Get in touch
      </p>
      <h2 class="mb-5 text-white">Get a Free Quote</h2>
      <p class="mb-8 max-w-xl text-lg text-white/85">
        Drop your address and pickup day below and we'll send back exact
        pricing within one business day. Prefer to talk to a human? We're a
        text or a call away.
      </p>

      <ul class="space-y-4">
        <li class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-brand-mint">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </span>
          <a href={site.phoneHref} class="text-lg font-semibold hover:text-brand-mint">
            {site.phone}
          </a>
        </li>
        <li class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-brand-mint">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </span>
          <a href={site.emailHref} class="text-lg font-semibold hover:text-brand-mint">
            {site.email}
          </a>
        </li>
        <li class="flex items-center gap-3 text-white/80">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-brand-mint">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </span>
          <span>{site.hours}</span>
        </li>
      </ul>
    </div>

    {/*
      ───────────────────────────────────────────────────────────────
      LEGACY CUSTOM FORM — disabled 2026-06-22 in favor of My Route Pro.
      Kept intentionally so we can revert to a self-hosted form / API
      submission (Formspree, Vercel, or chosen CRM) if needed.
      To revert: re-enable this block and remove the My Route Pro button below.
      ───────────────────────────────────────────────────────────────

      TODO: wire up form action (Vercel Forms / Formspree / chosen CRM) at deploy time
      <form
        action="#"
        method="post"
        class="rounded-xl2 bg-white p-6 sm:p-8 text-ink shadow-card"
        novalidate
      >
        <p class="mb-6 font-display text-xl font-extrabold text-brand-navy">
          Tell us about your bins
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="sm:col-span-1">
            <label for="name" class="mb-1 block text-sm font-semibold text-brand-navy">
              Name
            </label>
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              required
              class="w-full rounded-lg border border-brand-navy/15 bg-white px-4 py-3 text-base focus:border-brand-blue focus:ring-1 focus:ring-brand-blue"
            />
          </div>
          <div class="sm:col-span-1">
            <label for="phone" class="mb-1 block text-sm font-semibold text-brand-navy">
              Phone
            </label>
            <input
              id="phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              required
              class="w-full rounded-lg border border-brand-navy/15 bg-white px-4 py-3 text-base focus:border-brand-blue focus:ring-1 focus:ring-brand-blue"
            />
          </div>
          <div class="sm:col-span-2">
            <label for="email" class="mb-1 block text-sm font-semibold text-brand-navy">
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="w-full rounded-lg border border-brand-navy/15 bg-white px-4 py-3 text-base focus:border-brand-blue focus:ring-1 focus:ring-brand-blue"
            />
          </div>
          <div class="sm:col-span-2">
            <label for="address" class="mb-1 block text-sm font-semibold text-brand-navy">
              Service Address
            </label>
            <input
              id="address"
              name="address"
              type="text"
              autocomplete="street-address"
              required
              class="w-full rounded-lg border border-brand-navy/15 bg-white px-4 py-3 text-base focus:border-brand-blue focus:ring-1 focus:ring-brand-blue"
            />
          </div>
          <div class="sm:col-span-2">
            <label for="pickup" class="mb-1 block text-sm font-semibold text-brand-navy">
              Pickup Day <span class="font-normal text-ink/60">(optional)</span>
            </label>
            <select
              id="pickup"
              name="pickup"
              class="w-full rounded-lg border border-brand-navy/15 bg-white px-4 py-3 text-base focus:border-brand-blue focus:ring-1 focus:ring-brand-blue"
            >
              <option value="">Not sure yet</option>
              <option>Monday</option>
              <option>Tuesday</option>
              <option>Wednesday</option>
              <option>Thursday</option>
              <option>Friday</option>
            </select>
          </div>
          <div class="sm:col-span-2">
            <label for="message" class="mb-1 block text-sm font-semibold text-brand-navy">
              Anything else? <span class="font-normal text-ink/60">(optional)</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full rounded-lg border border-brand-navy/15 bg-white px-4 py-3 text-base focus:border-brand-blue focus:ring-1 focus:ring-brand-blue"
            ></textarea>
          </div>
        </div>

        <button type="submit" class="btn-primary mt-6 w-full">
          Request My Free Quote
        </button>

        <p class="mt-3 text-center text-xs text-ink/60">
          We'll never share your info. Expect a reply within one business day.
        </p>
      </form>
    */}

    {/* My Route Pro booking widget (added 2026-06-22) */}
    <div class="rounded-xl2 bg-white p-6 sm:p-8 text-ink shadow-card">
      <p class="mb-2 font-display text-xl font-extrabold text-brand-navy">
        Tell us about your bins
      </p>
      <p class="mb-6 text-base text-ink/70">
        Sign up online in a couple of minutes — pick your service, address, and
        pickup day, and we'll take it from there.
      </p>

      <button
        type="button"
        onclick="mrpSignUp('grand-valley-can-blasters')"
        class="btn-primary w-full"
      >
        Get a Free Quote
      </button>

      <a
        href="https://mrpbincleaning.myroutepro.com/customer-login?business=grand-valley-can-blasters"
        class="btn-secondary mt-3 w-full"
        target="_blank"
        rel="noopener"
      >
        Customer Login
      </a>

      <p class="mt-3 text-center text-xs text-ink/60">
        Already a customer? Log in to manage your account and schedule.
      </p>
    </div>
  </div>
</section>
