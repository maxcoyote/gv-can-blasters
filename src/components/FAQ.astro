---
import { faqs } from '../data/site';
---

<section id="faq" class="bg-brand-mint/30 py-20 sm:py-24">
  <div class="container-x">
    <div class="max-w-2xl">
      <p class="eyebrow mb-3">FAQ</p>
      <h2 class="mb-4">Frequently Asked Questions</h2>
      <p class="text-lg text-ink/80">
        Quick answers about service, scheduling, and how the eco-friendly water
        reclamation works.
      </p>
    </div>

    <div class="mt-10 mx-auto max-w-3xl divide-y divide-brand-navy/10 rounded-xl2 bg-white shadow-card ring-1 ring-brand-navy/5">
      {
        faqs.map((faq, i) => (
          <details
            class="group px-5 sm:px-7 py-5 open:bg-brand-mint/10"
            open={i === 0}
          >
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
              <span class="font-display text-lg font-bold text-brand-navy">
                {faq.q}
              </span>
              <span
                aria-hidden="true"
                class="mt-1 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-blue/10 text-brand-blue transition-transform group-open:rotate-45"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                >
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
              </span>
            </summary>
            <p class="mt-3 text-ink/80">{faq.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
