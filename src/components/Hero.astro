---
import { site } from '../data/site';
---

<section
  id="top"
  class="relative isolate overflow-hidden bg-gradient-to-b from-brand-sky/40 via-white to-white"
>
  <!-- Decorative mesa silhouette -->
  <svg
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 -z-10 h-40 w-full text-brand-sand/40"
    viewBox="0 0 1200 160"
    preserveAspectRatio="none"
  >
    <path
      d="M0 160 L0 110 L120 90 L260 70 L320 60 L420 80 L560 50 L700 70 L820 40 L980 65 L1120 50 L1200 80 L1200 160 Z"
      fill="currentColor"
    />
  </svg>

  <div class="container-x pt-10 pb-20 sm:pt-16 sm:pb-28 lg:pt-20 lg:pb-32">
    <div class="max-w-3xl">
      <p class="eyebrow mb-4">
        Grand Junction · Fruita · Palisade
      </p>

      <h1 class="mb-5">
        Trash Can Cleaning Service in
        <span class="text-brand-blue">Grand Junction, Fruita & Palisade</span>
      </h1>

      <p class="mb-8 max-w-2xl text-lg sm:text-xl text-ink/80">
        Hot-water, eco-friendly bin cleaning that sanitizes, deodorizes, and
        leaves your cans truly fresh. Locally owned, right here in the Grand
        Valley.
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <a href="#contact" class="btn-primary">
          Get a Free Quote
          <span aria-hidden="true">→</span>
        </a>
        <a href={site.phoneHref} class="btn-secondary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"></path>
          </svg>
          Call or Text {site.phone}
        </a>
      </div>

      <p class="mt-8 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-brand-green">
        <span class="h-2 w-2 rounded-full bg-brand-green"></span>
        {site.tagline}
      </p>
    </div>
  </div>
</section>
