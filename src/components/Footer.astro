---
import { site, nav, serviceAreas } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="bg-brand-navy text-white">
  <div class="container-x grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <div class="flex items-center gap-3">
        <img
          src="/logo.png"
          alt={site.name + ' logo'}
          width="48"
          height="48"
          class="h-12 w-12 rounded-md object-contain bg-white/5 p-1"
          loading="lazy"
          decoding="async"
        />
        <span class="font-display text-lg font-extrabold">{site.name}</span>
      </div>
      <p class="mt-4 max-w-xs text-sm text-white/75">
        Locally owned hot-water bin cleaning for the Grand Valley.
      </p>
      <p class="mt-4 text-xs font-semibold uppercase tracking-[0.18em] text-brand-mint">
        {site.tagline}
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white/70">
        Explore
      </h3>
      <ul class="mt-4 space-y-2 text-sm">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class="text-white/85 hover:text-brand-mint">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white/70">
        Service Area
      </h3>
      <ul class="mt-4 space-y-2 text-sm">
        {
          serviceAreas.map((a) => (
            <li class="text-white/85">{a.city}, CO</li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white/70">
        Contact
      </h3>
      <ul class="mt-4 space-y-2 text-sm">
        <li>
          <a href={site.phoneHref} class="text-white/90 hover:text-brand-mint">
            {site.phone}
          </a>
        </li>
        <li>
          <a href={site.emailHref} class="text-white/90 hover:text-brand-mint">
            {site.email}
          </a>
        </li>
        <li class="text-white/75">{site.hours}</li>
        {/* ⚠️ Social links TBD */}
        {site.social.facebook || site.social.instagram ? (
          <li class="mt-3 flex items-center gap-3">
            {site.social.facebook && (
              <a
                href={site.social.facebook}
                rel="noopener"
                target="_blank"
                aria-label="Facebook"
                class="text-white/75 hover:text-brand-mint"
              >
                FB
              </a>
            )}
            {site.social.instagram && (
              <a
                href={site.social.instagram}
                rel="noopener"
                target="_blank"
                aria-label="Instagram"
                class="text-white/75 hover:text-brand-mint"
              >
                IG
              </a>
            )}
          </li>
        ) : null}
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-x flex flex-col items-center justify-between gap-2 py-5 text-xs text-white/60 sm:flex-row">
      <p>© {year} {site.name}. All rights reserved.</p>
      <p>Grand Junction · Fruita · Palisade, CO</p>
    </div>
  </div>
</footer>
