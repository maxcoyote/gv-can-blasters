---
import { services } from '../data/site';
---

<section id="services" class="bg-white py-20 sm:py-24">
  <div class="container-x">
    <div class="max-w-2xl">
      <p class="eyebrow mb-3">Services</p>
      <h2 class="mb-4">Our Bin Cleaning Services</h2>
      <p class="text-lg text-ink/75">
        Hot-water sanitizing for residential trash cans and recycle bins across
        the Grand Valley. Pick a recurring plan or schedule a one-time deep clean.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <article
            class={
              'card flex flex-col ' +
              (s.featured
                ? 'ring-2 ring-brand-blue/60 shadow-[0_10px_30px_-12px_rgba(0,94,226,0.35)]'
                : '')
            }
          >
            {s.featured && (
              <p class="mb-3 inline-flex w-fit items-center rounded-full bg-brand-blue/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-blue">
                Most Popular
              </p>
            )}
            <h3 class="mb-2">{s.title}</h3>
            <p class="mb-6 text-ink/75">{s.body}</p>
            <div class="mt-auto flex items-center justify-between">
              <span class="text-sm font-semibold text-brand-navy/80">
                {s.price}
              </span>
              <a
                href="#contact"
                class="text-sm font-semibold text-brand-blue hover:text-brand-navy"
              >
                Get a quote →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
