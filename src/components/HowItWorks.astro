---
import { howItWorks } from '../data/site';
---

<section id="how-it-works" class="bg-brand-mint/30 py-20 sm:py-24">
  <div class="container-x">
    <div class="max-w-2xl">
      <p class="eyebrow mb-3">How It Works</p>
      <h2 class="mb-4">How we get your cans truly clean</h2>
      <p class="text-lg text-ink/75">
        Booking takes about a minute — after that, here's exactly what happens
        to your cans. No contracts, and you never need to be home.
      </p>
    </div>

    {/* Tyler's "good enough for now" demo cut — swap the <source src> + poster when the reshoot lands. */}
    <div
      class="group relative mt-10 aspect-video w-full overflow-hidden rounded-2xl bg-brand-navy/5 shadow-sm"
      data-video-wrap
    >
      <video
        class="h-full w-full object-cover"
        playsinline
        preload="none"
        poster="/media/how-it-works-poster.jpg"
        aria-label="Grand Valley Can Blasters cleaning process video"
        data-video
      >
        <source src="/media/how-it-works.mp4" type="video/mp4" />
        Your browser doesn't support embedded video.
        <a href="/media/how-it-works.mp4">Download the video</a> instead.
      </video>

      <button
        type="button"
        class="absolute inset-0 flex items-center justify-center bg-brand-navy/30 transition-colors duration-300 hover:bg-brand-navy/40 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-inset focus-visible:ring-brand-blue/60"
        aria-label="Play the Grand Valley Can Blasters cleaning process video"
        data-video-play
      >
        <span
          class="flex h-20 w-20 items-center justify-center rounded-full bg-brand-blue text-white shadow-lg ring-4 ring-white/30 transition-transform duration-300 group-hover:scale-110"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="ml-1 h-8 w-8" aria-hidden="true">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
      </button>
    </div>

    <ol class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        howItWorks.map((step) => (
          <li class="card relative flex flex-col">
            <span
              aria-hidden="true"
              class="absolute -top-5 left-6 inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-blue text-white font-display text-lg font-extrabold shadow-card"
            >
              {step.n}
            </span>
            <h3 class="mb-2 mt-6">{step.title}</h3>
            <p class="text-ink/75">{step.body}</p>
          </li>
        ))
      }
    </ol>

    <div class="mt-12 flex justify-center">
      <a href="#contact" class="btn-primary">Book Your First Clean</a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-video-wrap]').forEach((wrap) => {
    const video = wrap.querySelector<HTMLVideoElement>('[data-video]');
    const playBtn = wrap.querySelector<HTMLButtonElement>('[data-video-play]');
    if (!video || !playBtn) return;

    playBtn.addEventListener('click', () => {
      video.setAttribute('controls', '');
      playBtn.remove();
      void video.play();
    });
  });
</script>
