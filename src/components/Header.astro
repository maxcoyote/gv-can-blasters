---
import { site, nav } from '../data/site';
---

<!--
  Zero-height sentinel anchored to the top of the document. The header's
  "scrolled" state is driven by whether this element is in view (via
  IntersectionObserver) rather than a scrollY threshold — so it can't thrash
  frame-to-frame the way a single-threshold scroll handler does.
-->
<div
  id="nav-sentinel"
  aria-hidden="true"
  style="position:absolute;top:0;left:0;height:24px;width:1px;pointer-events:none;"
>
</div>

<header
  data-site-header
  class="site-header sticky top-0 z-40 border-b border-brand-navy/5 bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/75"
>
  <div class="container-x flex items-center justify-between gap-4 py-1">
    <a href="#top" class="flex items-center" aria-label={site.name + ' — home'}>
      <img
        src="/logo.png"
        alt={site.name + ' logo'}
        width="160"
        height="160"
        class="site-logo h-32 w-32 sm:h-40 sm:w-40 object-contain"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav aria-label="Primary" class="hidden lg:block">
      <ul class="flex items-center gap-7 text-sm font-semibold text-brand-navy">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="hover:text-brand-blue transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={site.phoneHref}
        class="hidden md:inline-flex text-sm font-semibold text-brand-navy hover:text-brand-blue transition-colors"
        aria-label={'Call ' + site.name}
      >
        {site.phone}
      </a>
      <a href="#contact" class="btn-primary text-sm sm:text-base px-5 py-2.5">
        Book Now
      </a>
    </div>
  </div>

  <!-- Mobile sub-nav -->
  <nav aria-label="Mobile" class="lg:hidden border-t border-brand-navy/5 bg-white">
    <ul class="container-x flex items-center gap-5 overflow-x-auto py-2 text-sm font-semibold text-brand-navy">
      {
        nav.map((item) => (
          <li class="shrink-0">
            <a
              href={item.href}
              class="block py-1 hover:text-brand-blue transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  /* Ease only the specific properties that change — never height of an
     element that reflows the page. */
  .site-header {
    transition:
      background-color 200ms ease,
      box-shadow 200ms ease;
  }
  .site-logo {
    transition:
      height 220ms ease,
      width 220ms ease;
  }

  .site-header.is-scrolled {
    box-shadow: 0 6px 24px -12px rgba(11, 27, 43, 0.25);
  }
  .site-header.is-scrolled .site-logo {
    height: 3rem;
    width: 3rem;
  }
  @media (min-width: 640px) {
    .site-header.is-scrolled .site-logo {
      height: 3.5rem;
      width: 3.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .site-logo {
      transition: none;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  const sentinel = document.getElementById('nav-sentinel');

  if (header) {
    if (sentinel && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        ([entry]) => {
          header.classList.toggle('is-scrolled', !entry.isIntersecting);
        },
        { rootMargin: '0px', threshold: 0 }
      );
      io.observe(sentinel);
    } else {
      // Fallback for environments without IntersectionObserver: hysteresis +
      // rAF-coalesced passive scroll listener so it still can't thrash.
      let ticking = false;
      const update = () => {
        const y = window.scrollY;
        if (y > 80) header.classList.add('is-scrolled');
        else if (y < 40) header.classList.remove('is-scrolled');
        ticking = false;
      };
      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
          }
        },
        { passive: true }
      );
      update();
    }
  }
</script>
